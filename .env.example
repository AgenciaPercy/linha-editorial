# Postgres (Railway expõe automaticamente via referência ${{Postgres.DATABASE_URL}})
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# Senha opcional para proteger /admin no futuro (header x-admin-password).
# Deixe vazio para manter o admin aberto no MVP.
ADMIN_PASSWORD=""

# Pasta onde as imagens enviadas (agência/cliente) são salvas.
# Em produção no Railway, deve apontar para o mount path do Volume.
UPLOAD_DIR="./uploads-data"

# URL pública da aplicação (usada para montar links de aprovação)
NEXT_PUBLIC_BASE_URL="http://localhost:3000"
